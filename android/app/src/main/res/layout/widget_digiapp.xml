<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="10dp"
    android:background="@drawable/partner_area"
    android:gravity="center_vertical">

    <!-- Sprite (left) — 2-frame bounce via ViewFlipper -->
    <ViewFlipper
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:autoStart="true"
        android:flipInterval="450">
        <ImageView
            android:id="@+id/widget_sprite"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerInside"
            android:src="@drawable/triceramon_dot" />
        <ImageView
            android:id="@+id/widget_sprite_2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerInside"
            android:paddingBottom="5dp"
            android:src="@drawable/triceramon_dot" />
    </ViewFlipper>

    <!-- Text column (right) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp"
        android:gravity="center_vertical">

        <!-- Digimon name -->
        <TextView
            android:id="@+id/widget_digimon_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DigiEgg"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:maxLines="1"
            android:ellipsize="end"
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2" />

        <!-- Stage label -->
        <TextView
            android:id="@+id/widget_stage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ovo Digital"
            android:textSize="10sp"
            android:textColor="#CCFFFFFF"
            android:maxLines="1" />

        <!-- Task progress -->
        <TextView
            android:id="@+id/widget_tasks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:maxLines="1"
            android:layout_marginTop="2dp" />

        <!-- Contextual message -->
        <TextView
            android:id="@+id/widget_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Adicione tarefas!"
            android:textSize="10sp"
            android:textColor="#CCFFFFFF"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

</LinearLayout>
