<?xml version="1.0" encoding="utf-8"?>
<!-- Pet-screen widget: green grid + hearts (top-left) + animated pet (center) + energy bar (right). -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp"
    android:background="@drawable/partner_area">

    <!-- Hearts (top-left) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true">
        <ImageView android:id="@+id/widget_heart_1" android:layout_width="15dp" android:layout_height="15dp" android:layout_marginEnd="2dp" android:src="@drawable/heart_full" />
        <ImageView android:id="@+id/widget_heart_2" android:layout_width="15dp" android:layout_height="15dp" android:layout_marginEnd="2dp" android:src="@drawable/heart_empty" />
        <ImageView android:id="@+id/widget_heart_3" android:layout_width="15dp" android:layout_height="15dp" android:layout_marginEnd="2dp" android:src="@drawable/heart_empty" />
        <ImageView android:id="@+id/widget_heart_4" android:layout_width="15dp" android:layout_height="15dp" android:layout_marginEnd="2dp" android:src="@drawable/heart_empty" />
        <ImageView android:id="@+id/widget_heart_5" android:layout_width="15dp" android:layout_height="15dp" android:src="@drawable/heart_empty" />
    </LinearLayout>

    <!-- Energy bar (right, vertical, fills from bottom) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="bottom"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true">
        <View android:id="@+id/widget_energy_5" android:layout_width="9dp" android:layout_height="0dp" android:layout_weight="1" android:layout_marginBottom="2dp" android:background="@drawable/bar_off" />
        <View android:id="@+id/widget_energy_4" android:layout_width="9dp" android:layout_height="0dp" android:layout_weight="1" android:layout_marginBottom="2dp" android:background="@drawable/bar_off" />
        <View android:id="@+id/widget_energy_3" android:layout_width="9dp" android:layout_height="0dp" android:layout_weight="1" android:layout_marginBottom="2dp" android:background="@drawable/bar_off" />
        <View android:id="@+id/widget_energy_2" android:layout_width="9dp" android:layout_height="0dp" android:layout_weight="1" android:layout_marginBottom="2dp" android:background="@drawable/bar_off" />
        <View android:id="@+id/widget_energy_1" android:layout_width="9dp" android:layout_height="0dp" android:layout_weight="1" android:background="@drawable/bar_off" />
    </LinearLayout>

    <!-- Pet sprite (center) — 2-frame breathing -->
    <ViewFlipper
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:layout_centerInParent="true"
        android:autoStart="true"
        android:flipInterval="450">
        <ImageView
            android:id="@+id/widget_sprite"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:scaleType="fitEnd" android:src="@drawable/triceramon_dot" />
        <ImageView
            android:id="@+id/widget_sprite_2"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:scaleType="fitEnd" android:paddingTop="6dp" android:src="@drawable/triceramon_dot" />
    </ViewFlipper>

</RelativeLayout>
